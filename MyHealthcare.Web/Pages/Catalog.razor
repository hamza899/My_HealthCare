@page "/catalog"
@inject CategoryService CategoryService
@inject MedicineService MedicineService
@inject NavigationManager Nav

<PageTitle>Browse Medicines - My Healthcare</PageTitle>

<div class="mb-4">
    <h1 class="section-title">Browse Medicines</h1>
    @if (!string.IsNullOrEmpty(searchQuery))
    {
        <p class="text-muted mb-0">
            Showing results for <strong>"@searchQuery"</strong>
            <button class="btn btn-link btn-sm p-0 ms-2" @onclick="ClearSearch">
                <i class="bi bi-x-circle"></i> clear
            </button>
        </p>
    }
</div>

<div class="mb-4">
    <div class="d-flex flex-wrap gap-2">
        <button class="filter-pill @(string.IsNullOrEmpty(selectedCategoryId) ? "active" : "")"
                @onclick="@(() => SelectCategory(null))">
            All
        </button>
        @if (categories is not null)
        {
            @foreach (var c in categories)
            {
                <button class="filter-pill @(selectedCategoryId == c.Id ? "active" : "")"
                        @onclick="@(() => SelectCategory(c.Id))">
                    @c.Name
                </button>
            }
        }
    </div>
</div>

@if (medicines is null)
{
    <LoadingSpinner Message="Loading medicines..." />
}
else if (!medicines.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search" style="font-size: 4rem; color: var(--text-muted);"></i>
        <h4 class="mt-3">No medicines found</h4>
        <p class="text-muted">Try a different search or category</p>
        <button class="btn btn-outline-primary" @onclick="ClearAll">Clear filters</button>
    </div>
}
else
{
    <div class="mb-3 text-muted">
        <small>@totalCount medicine@(totalCount == 1 ? "" : "s") found</small>
    </div>
    <div class="row g-3">
        @foreach (var m in medicines)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <MedicineCard Medicine="m" />
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? Search { get; set; }
    [SupplyParameterFromQuery] public string? CategoryId { get; set; }

    private List<CategoryDto>? categories;
    private List<MedicineDto>? medicines;
    private string? searchQuery;
    private string? selectedCategoryId;
    private long totalCount;

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAllAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        searchQuery = Search;
        selectedCategoryId = CategoryId;
        await LoadMedicines();
    }

    private async Task LoadMedicines()
    {
        medicines = null;
        StateHasChanged();
        var loadTask = MedicineService.GetAllAsync(
            search: searchQuery,
            categoryId: selectedCategoryId,
            pageSize: 50);
        var countTask = MedicineService.GetCountAsync(
            search: searchQuery,
            categoryId: selectedCategoryId);

        await Task.WhenAll(loadTask, countTask);
        medicines = await loadTask;
        totalCount = await countTask;
    }

    private void SelectCategory(string? id)
    {
        var query = new List<string>();
        if (!string.IsNullOrEmpty(searchQuery)) query.Add($"search={Uri.EscapeDataString(searchQuery)}");
        if (!string.IsNullOrEmpty(id)) query.Add($"categoryId={id}");
        var url = "catalog" + (query.Any() ? "?" + string.Join("&", query) : "");
        Nav.NavigateTo(url);
    }

    private void ClearSearch()
    {
        var url = string.IsNullOrEmpty(selectedCategoryId)
            ? "catalog"
            : $"catalog?categoryId={selectedCategoryId}";
        Nav.NavigateTo(url);
    }

    private void ClearAll() => Nav.NavigateTo("catalog");
}
