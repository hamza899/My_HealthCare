@page "/order-confirmation/{Id}"
@inject OrderService Orders
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Order Confirmed - My Healthcare</PageTitle>

@if (loading)
{
    <LoadingSpinner />
}
else if (order is null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-circle" style="font-size: 4rem; color: var(--text-muted);"></i>
        <h4 class="mt-3">Order not found</h4>
        <a href="orders" class="btn btn-primary mt-2">My Orders</a>
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center py-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width: 100px; height: 100px; background: var(--primary-light); color: var(--primary);">
                    <i class="bi bi-check-lg" style="font-size: 4rem;"></i>
                </div>
                <h2 class="mt-3 fw-bold">Order Confirmed!</h2>
                <p class="text-muted mb-1">Thank you for your order, <strong>@Auth.CurrentUser?.FullName</strong></p>
                <p class="text-muted small">
                    Order # <code class="user-select-all">@order.OrderNumber</code>
                </p>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-bag-check me-2"></i>Order Details</h5>

                    @foreach (var item in order.Items)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <div>
                                <div>@item.MedicineName</div>
                                <small class="text-muted">Qty: @item.Quantity × Rs @item.UnitPrice.ToString("N0")</small>
                            </div>
                            <div class="fw-medium">Rs @item.Subtotal.ToString("N0")</div>
                        </div>
                    }

                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span class="text-primary fs-5">Rs @order.TotalAmount.ToString("N0")</span>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title"><i class="bi bi-geo-alt me-2"></i>Delivery Address</h6>
                            <div class="small">
                                <strong>@order.DeliveryAddress.FullName</strong><br />
                                @order.DeliveryAddress.Phone<br />
                                @order.DeliveryAddress.Street<br />
                                @order.DeliveryAddress.City
                                @(string.IsNullOrEmpty(order.DeliveryAddress.PostalCode) ? "" : $" - {order.DeliveryAddress.PostalCode}")
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title"><i class="bi bi-credit-card me-2"></i>Payment</h6>
                            <div class="small">
                                <strong>
                                    @(order.PaymentMethod == PaymentMethod.CashOnDelivery
                                        ? "Cash on Delivery" : "Card Payment")
                                </strong><br />
                                Status:
                                <span class="badge bg-warning text-dark">@order.PaymentStatus</span>
                            </div>
                            <hr />
                            <h6 class="card-subtitle mb-2"><i class="bi bi-clock-history me-1"></i>Order Status</h6>
                            <span class="badge bg-info">@order.OrderStatus</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <i class="bi bi-info-circle me-2"></i>
                Hamari team aap ko phone pe contact karegi delivery confirm karne ke liye.
                Approximate delivery: <strong>2-3 business days</strong>.
            </div>

            <div class="d-flex gap-2 justify-content-center mt-4">
                <a href="orders" class="btn btn-outline-primary">
                    <i class="bi bi-receipt me-2"></i> My Orders
                </a>
                <a href="catalog" class="btn btn-primary">
                    <i class="bi bi-capsule me-2"></i> Continue Shopping
                </a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private OrderDto? order;
    private bool loading = true;

    protected override async Task OnParametersSetAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }
        loading = true;
        order = await Orders.GetByIdAsync(Id);
        loading = false;
    }
}
