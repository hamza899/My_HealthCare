@page "/medicine/{Id}"
@inject MedicineService MedicineService
@inject CartService Cart
@inject NavigationManager Nav

<PageTitle>@(medicine?.Name ?? "Medicine") - My Healthcare</PageTitle>

@if (loading)
{
    <LoadingSpinner Message="Loading medicine..." />
}
else if (medicine is null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-circle" style="font-size: 4rem; color: var(--text-muted);"></i>
        <h4 class="mt-3">Medicine not found</h4>
        <a href="catalog" class="btn btn-primary mt-2">Browse Catalog</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="">Home</a></li>
            <li class="breadcrumb-item"><a href="catalog">Catalog</a></li>
            @if (!string.IsNullOrEmpty(medicine.CategoryName))
            {
                <li class="breadcrumb-item">
                    <a href="@($"catalog?categoryId={medicine.CategoryId}")">@medicine.CategoryName</a>
                </li>
            }
            <li class="breadcrumb-item active">@medicine.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="medicine-card">
                <div class="image" style="aspect-ratio: 1; font-size: 6rem;">
                    @if (!string.IsNullOrEmpty(medicine.ImageUrl))
                    {
                        <img src="@medicine.ImageUrl" alt="@medicine.Name" class="img-fluid" />
                    }
                    else
                    {
                        <i class="bi bi-capsule"></i>
                    }
                    @if (medicine.PrescriptionRequired)
                    {
                        <span class="rx-badge">Rx Required</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="brand text-uppercase text-muted small mb-1">@medicine.Brand</div>
            <h1 class="h3 fw-bold mb-2">@medicine.Name</h1>
            @if (!string.IsNullOrEmpty(medicine.Manufacturer))
            {
                <p class="text-muted small">By @medicine.Manufacturer</p>
            }

            <div class="d-flex align-items-center gap-3 my-3">
                <span class="h2 fw-bold mb-0 text-primary">Rs @medicine.EffectivePrice.ToString("N0")</span>
                @if (medicine.DiscountPrice.HasValue)
                {
                    <span class="text-decoration-line-through text-muted">Rs @medicine.Price.ToString("N0")</span>
                    var pct = (int)Math.Round((1 - (double)(medicine.DiscountPrice.Value / medicine.Price)) * 100);
                    <span class="badge bg-warning text-dark">-@pct% OFF</span>
                }
            </div>

            <div class="mb-3">
                @if (medicine.InStock)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i> In Stock (@medicine.StockQuantity available)
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        <i class="bi bi-x-circle me-1"></i> Out of Stock
                    </span>
                }
                @if (medicine.PrescriptionRequired)
                {
                    <span class="badge bg-danger ms-2">
                        <i class="bi bi-clipboard2-pulse me-1"></i> Prescription Required
                    </span>
                }
            </div>

            <p class="text-secondary">@medicine.Description</p>

            <div class="d-flex align-items-center gap-2 my-4">
                <label class="me-2 fw-medium">Quantity:</label>
                <div class="input-group" style="max-width: 140px;">
                    <button class="btn btn-outline-secondary" type="button"
                            @onclick="@(() => quantity = Math.Max(1, quantity - 1))"
                            disabled="@(!medicine.InStock)">
                        <i class="bi bi-dash"></i>
                    </button>
                    <input type="number" class="form-control text-center"
                           value="@quantity" min="1" max="@medicine.StockQuantity"
                           @onchange="@(e => SetQuantity(e.Value?.ToString()))"
                           disabled="@(!medicine.InStock)" />
                    <button class="btn btn-outline-secondary" type="button"
                            @onclick="@(() => quantity = Math.Min(medicine.StockQuantity, quantity + 1))"
                            disabled="@(!medicine.InStock)">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-lg flex-grow-1"
                        disabled="@(!medicine.InStock || adding)"
                        @onclick="AddToCart">
                    @if (added)
                    {
                        <i class="bi bi-check-circle me-2"></i> <span>Added to Cart</span>
                    }
                    else
                    {
                        <i class="bi bi-cart-plus me-2"></i> <span>Add to Cart</span>
                    }
                </button>
                <button class="btn btn-outline-primary btn-lg"
                        disabled="@(!medicine.InStock || adding)"
                        @onclick="BuyNow">
                    <i class="bi bi-lightning-charge me-2"></i> Buy Now
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        @if (medicine.Ingredients?.Any() == true)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Ingredients</h5>
                        <ul class="mb-0">
                            @foreach (var ing in medicine.Ingredients)
                            {
                                <li>@ing</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(medicine.Usage))
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-info-circle me-2"></i>Usage</h5>
                        <p class="mb-0">@medicine.Usage</p>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(medicine.SideEffects))
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-exclamation-triangle me-2"></i>Side Effects</h5>
                        <p class="mb-0">@medicine.SideEffects</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private MedicineDto? medicine;
    private bool loading = true;
    private int quantity = 1;
    private bool adding;
    private bool added;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        added = false;
        medicine = await MedicineService.GetByIdAsync(Id);
        loading = false;
    }

    private void SetQuantity(string? value)
    {
        if (int.TryParse(value, out var q) && q > 0 && medicine is not null)
        {
            quantity = Math.Min(q, medicine.StockQuantity);
        }
    }

    private async Task AddToCart()
    {
        if (medicine is null) return;
        adding = true;
        await Cart.AddAsync(medicine, quantity);
        adding = false;
        added = true;
        StateHasChanged();
        await Task.Delay(1500);
        added = false;
        StateHasChanged();
    }

    private async Task BuyNow()
    {
        if (medicine is null) return;
        await Cart.AddAsync(medicine, quantity);
        Nav.NavigateTo("cart");
    }
}
