@page "/admin"
@layout AdminLayout
@inject AdminService Admin
@inject AuthService Auth

<PageTitle>Admin Dashboard - My Healthcare</PageTitle>

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>

@if (loading)
{
    <LoadingSpinner />
}
else if (stats is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Could not load dashboard stats.
        <button class="btn btn-sm btn-outline-primary ms-2" @onclick="Load">Retry</button>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card text-center h-100">
                <div class="card-body">
                    <i class="bi bi-currency-rupee text-success" style="font-size: 2rem;"></i>
                    <h6 class="text-muted mt-2 mb-1">Revenue</h6>
                    <h4 class="fw-bold text-success mb-0">Rs @stats.TotalRevenue.ToString("N0")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center h-100">
                <div class="card-body">
                    <i class="bi bi-receipt text-primary" style="font-size: 2rem;"></i>
                    <h6 class="text-muted mt-2 mb-1">Total Orders</h6>
                    <h4 class="fw-bold mb-0">@stats.TotalOrders</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center h-100">
                <div class="card-body">
                    <i class="bi bi-people text-info" style="font-size: 2rem;"></i>
                    <h6 class="text-muted mt-2 mb-1">Customers</h6>
                    <h4 class="fw-bold mb-0">@stats.TotalCustomers</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center h-100">
                <div class="card-body">
                    <i class="bi bi-capsule text-warning" style="font-size: 2rem;"></i>
                    <h6 class="text-muted mt-2 mb-1">Medicines</h6>
                    <h4 class="fw-bold mb-0">@stats.TotalMedicines</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-clock-history me-2"></i>Order Status</h5>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <span class="badge bg-warning text-dark">Pending</span>
                            <span class="ms-2">Need attention</span>
                        </div>
                        <span class="fw-bold">@stats.PendingOrders</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <span class="badge bg-success">Delivered</span>
                            <span class="ms-2">Completed</span>
                        </div>
                        <span class="fw-bold">@stats.DeliveredOrders</span>
                    </div>
                    <a href="admin/orders" class="btn btn-sm btn-outline-primary mt-3">
                        Manage Orders <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-exclamation-triangle text-warning me-2"></i>Low Stock Alert
                    </h5>
                    @if (!stats.LowStockMedicines.Any())
                    {
                        <p class="text-muted small mb-0">All medicines have healthy stock levels.</p>
                    }
                    else
                    {
                        @foreach (var m in stats.LowStockMedicines)
                        {
                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <span class="text-truncate me-2">@m.Name</span>
                                <span class="badge @(m.StockQuantity < 10 ? "bg-danger" : "bg-warning text-dark")">
                                    @m.StockQuantity left
                                </span>
                            </div>
                        }
                        <a href="admin/medicines" class="btn btn-sm btn-outline-primary mt-3">
                            Manage Stock <i class="bi bi-arrow-right"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private AdminStatsDto? stats;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        StateHasChanged();
        stats = await Admin.GetStatsAsync();
        loading = false;
    }
}
