@page "/"
@inject CategoryService CategoryService
@inject MedicineService MedicineService

<PageTitle>My Healthcare - Online Pharmacy</PageTitle>

<section class="hero">
    <div class="px-4 px-md-5">
        <div class="row align-items-center">
            <div class="col-md-7">
                <h1 class="display-5">Aap ki sehat, hamari zimmedari</h1>
                <p class="lead mb-4">
                    Pakistan ki sab se trusted online pharmacy. Original medicines, fast delivery,
                    aur affordable prices &mdash; ghar baithay order karein.
                </p>
                <a href="catalog" class="btn btn-light btn-lg">
                    <i class="bi bi-capsule me-2"></i> Browse Medicines
                </a>
            </div>
            <div class="col-md-5 text-center d-none d-md-block">
                <i class="bi bi-heart-pulse" style="font-size: 12rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <h2 class="section-title">Shop by Category</h2>
    @if (categories is null)
    {
        <LoadingSpinner />
    }
    else if (!categories.Any())
    {
        <div class="alert alert-warning">No categories available.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var c in categories)
            {
                <div class="col-6 col-sm-4 col-md-3">
                    <a class="category-card" href="@($"catalog?categoryId={c.Id}")">
                        <div class="category-icon">
                            <i class="bi @GetIcon(c.Slug)"></i>
                        </div>
                        <div class="name">@c.Name</div>
                    </a>
                </div>
            }
        </div>
    }
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title mb-0">Featured Medicines</h2>
        <a href="catalog" class="text-decoration-none">
            View All <i class="bi bi-arrow-right"></i>
        </a>
    </div>
    @if (featured is null)
    {
        <LoadingSpinner />
    }
    else if (!featured.Any())
    {
        <div class="alert alert-warning">No medicines available yet.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var m in featured)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <MedicineCard Medicine="m" />
                </div>
            }
        </div>
    }
</section>

@code {
    private List<CategoryDto>? categories;
    private List<MedicineDto>? featured;

    protected override async Task OnInitializedAsync()
    {
        var categoriesTask = CategoryService.GetAllAsync();
        var featuredTask = MedicineService.GetAllAsync(pageSize: 8);
        await Task.WhenAll(categoriesTask, featuredTask);
        categories = await categoriesTask;
        featured = await featuredTask;
    }

    private string GetIcon(string slug) => slug switch
    {
        "pain-relief" => "bi-bandaid",
        "vitamins" => "bi-capsule",
        "diabetes" => "bi-droplet-half",
        "heart-care" => "bi-heart-pulse",
        "skin-care" => "bi-flower1",
        "cold-flu" => "bi-thermometer",
        "baby-care" => "bi-emoji-smile",
        "first-aid" => "bi-bag-heart",
        _ => "bi-capsule-pill"
    };
}
