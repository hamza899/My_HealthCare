@page "/orders"
@inject OrderService OrdersSvc
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>My Orders - My Healthcare</PageTitle>

<h1 class="section-title">
    <i class="bi bi-receipt me-2"></i> My Orders
</h1>

@if (!ready)
{
    <LoadingSpinner />
}
else if (!Auth.IsAuthenticated)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-shield-lock text-primary" style="font-size: 4rem;"></i>
            <h4 class="mt-3">Sign In Required</h4>
            <a href="@($"login?returnUrl=orders")" class="btn btn-primary mt-2">
                <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
            </a>
        </div>
    </div>
}
else if (!orders.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag" style="font-size: 4rem; color: var(--text-muted);"></i>
        <h4 class="mt-3">No orders yet</h4>
        <p class="text-muted">Start shopping to see your orders here.</p>
        <a href="catalog" class="btn btn-primary">Browse Medicines</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var o in orders)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between flex-wrap gap-2 mb-2">
                            <div>
                                <div class="fw-bold">
                                    Order # <code>@o.OrderNumber</code>
                                </div>
                                <small class="text-muted">
                                    @o.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                                </small>
                            </div>
                            <div class="text-end">
                                <span class="badge @StatusBadge(o.OrderStatus)">@o.OrderStatus</span>
                                <div class="fw-bold mt-1 text-primary">Rs @o.TotalAmount.ToString("N0")</div>
                            </div>
                        </div>

                        <OrderTimeline Order="o" Compact="true" />

                        <hr class="my-2" />

                        <div class="small text-muted mb-2">
                            @o.Items.Count item@(o.Items.Count == 1 ? "" : "s") &middot;
                            @(o.PaymentMethod == PaymentMethod.CashOnDelivery ? "Cash on Delivery" : "Card") &middot;
                            @o.DeliveryAddress.City
                        </div>

                        <div class="small mb-2">
                            @string.Join(", ", o.Items.Take(3).Select(i => $"{i.MedicineName} × {i.Quantity}"))
                            @if (o.Items.Count > 3)
                            {
                                <span class="text-muted"> and @(o.Items.Count - 3) more</span>
                            }
                        </div>

                        <a href="@($"order-confirmation/{o.Id}")" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool ready;
    private List<OrderDto> orders = new();

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.IsAuthenticated)
        {
            orders = await OrdersSvc.GetMyOrdersAsync();
        }
        ready = true;
    }

    private static string StatusBadge(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Confirmed => "bg-info",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Delivered => "bg-success",
        OrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
