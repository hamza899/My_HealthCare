@inject NavigationManager Nav
@inject CartService Cart
@inject AuthService Auth
@implements IDisposable

<nav class="app-navbar">
    <div class="container">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <a class="navbar-brand" href="">
                <i class="bi bi-heart-pulse-fill"></i> My Healthcare
            </a>

            <div class="search-bar input-group flex-grow-1 mx-md-3" style="max-width: 500px;">
                <input type="text" class="form-control" placeholder="Search medicines, brands..."
                       @bind="searchText" @bind:event="oninput"
                       @onkeydown="OnSearchKeyDown" />
                <button class="btn" type="button" @onclick="DoSearch">
                    <i class="bi bi-search"></i>
                </button>
            </div>

            <div class="d-flex align-items-center gap-2 ms-auto">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door"></i>
                    <span class="d-none d-md-inline">Home</span>
                </NavLink>
                <NavLink class="nav-link" href="catalog">
                    <i class="bi bi-capsule"></i>
                    <span class="d-none d-md-inline">Catalog</span>
                </NavLink>
                <NavLink class="nav-link position-relative" href="cart">
                    <i class="bi bi-cart3"></i>
                    <span class="d-none d-md-inline">Cart</span>
                    @if (cartCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                              style="font-size: 0.65rem;">
                            @cartCount
                        </span>
                    }
                </NavLink>

                @if (Auth.IsAuthenticated)
                {
                    <div class="dropdown">
                        <button class="btn nav-link dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-md-inline">@FirstName</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="px-3 py-2 small text-muted">
                                Signed in as<br />
                                <strong class="text-dark">@Auth.CurrentUser?.Email</strong>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" href="orders"><i class="bi bi-receipt me-2"></i>My Orders</a></li>
                            @if (Auth.CurrentUser?.Role == UserRole.Admin)
                            {
                                <li><a class="dropdown-item" href="admin"><i class="bi bi-shield-lock me-2"></i>Admin Panel</a></li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <button class="dropdown-item text-danger" @onclick="HandleLogout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                </button>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <NavLink class="nav-link" href="login">
                        <i class="bi bi-person-circle"></i>
                        <span class="d-none d-md-inline">Sign In</span>
                    </NavLink>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    private string searchText = string.Empty;
    private int cartCount;

    private string FirstName => Auth.CurrentUser?.FullName?.Split(' ').FirstOrDefault() ?? "Account";

    protected override async Task OnInitializedAsync()
    {
        Cart.OnChange += RefreshCart;
        Auth.OnChange += RefreshAuth;
        await Auth.InitializeAsync();
        await RefreshCartAsync();
    }

    private async Task RefreshCartAsync()
    {
        cartCount = await Cart.GetItemCountAsync();
        StateHasChanged();
    }

    private void RefreshCart() => _ = RefreshCartAsync();
    private void RefreshAuth() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Cart.OnChange -= RefreshCart;
        Auth.OnChange -= RefreshAuth;
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoSearch();
    }

    private void DoSearch()
    {
        var query = string.IsNullOrWhiteSpace(searchText)
            ? "catalog"
            : $"catalog?search={Uri.EscapeDataString(searchText)}";
        Nav.NavigateTo(query);
    }

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("");
    }
}
