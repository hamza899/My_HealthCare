@inherits LayoutComponentBase

<NavMenu />

<main class="container py-4">
    @Body
</main>

<footer class="app-footer">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="footer-brand">
                    <i class="bi bi-heart-pulse-fill"></i> My Healthcare
                </div>
                <p class="footer-tagline">
                    Pakistan ki trusted online pharmacy. Original medicines, fast delivery,
                    aur affordable prices &mdash; ghar baithay order karein.
                </p>
                <div class="footer-social">
                    <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <h6 class="footer-heading">Shop</h6>
                <ul class="footer-links">
                    <li><a href="catalog">All Medicines</a></li>
                    <li><a href="catalog">Categories</a></li>
                    <li><a href="cart">Cart</a></li>
                </ul>
            </div>

            <div class="col-6 col-md-2">
                <h6 class="footer-heading">Account</h6>
                <ul class="footer-links">
                    <li><a href="login">Sign In</a></li>
                    <li><a href="register">Sign Up</a></li>
                    <li><a href="orders">My Orders</a></li>
                </ul>
            </div>

            <div class="col-md-4">
                <h6 class="footer-heading">Contact Us</h6>
                <ul class="footer-contact">
                    <li><i class="bi bi-telephone"></i> +92 300 000 0000</li>
                    <li><i class="bi bi-envelope"></i> support@myhealthcare.com</li>
                    <li><i class="bi bi-clock"></i> 9 AM &ndash; 9 PM (7 days)</li>
                </ul>
            </div>
        </div>

        <hr class="footer-divider" />

        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year My Healthcare. All rights reserved.
            </small>
            <small class="text-muted">
                <i class="bi bi-shield-lock"></i> Secure &middot; <i class="bi bi-truck"></i> Fast Delivery
            </small>
        </div>
    </div>
</footer>
