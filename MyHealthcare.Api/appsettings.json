{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "MongoDbSettings": {
    "ConnectionString": "REPLACE_WITH_YOUR_CONNECTION_STRING",
    "DatabaseName": "MyHealthcareDb"
  },

  "JwtSettings": {
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG_xxxxxxxxx",
    "Issuer": "MyHealthcareApi",
    "Audience": "MyHealthcareClient",
    "ExpiryMinutes": 1440
  }
}
